# Frontend (Vite)
VITE_APP_NAME=Napkin Audio AI Studio
VITE_PROVIDER_PROXY_URL=http://127.0.0.1:8787

# Provider proxy server (npm run server)
PORT=8787
CORS_ORIGIN=http://127.0.0.1:5173

# ElevenLabs: speech, sound effects, music, dubbing, voice changer
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# Local LLM autonomous production planning (Ollama). Required for the
# "generate full production plan" flow. See README.md > Local LLM (Ollama).
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3

# NVIDIA Riva / NIM (scaffolded adapters, not required for local MVP use)
NVIDIA_RIVA_ENDPOINT=
NVIDIA_RIVA_API_KEY=
NVIDIA_NIM_API_KEY=
